              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"IN_PROGRESS\",\n  \"priority\": \"MEDIUM\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/service-a/requests/1",
              "host": ["{{base_url}}"],
              "path": ["service-a", "requests", "1"]
            }
          }
        },
        {
          "name": "Delete Request",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/service-a/requests/1",
              "host": ["{{base_url}}"],
              "path": ["service-a", "requests", "1"]
            }
          }
        },
        {
          "name": "Add Comment to Request",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"Por favor, es urgente\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/service-a/requests/1/comments",
              "host": ["{{base_url}}"],
              "path": ["service-a", "requests", "1", "comments"]
            }
          }
        }
